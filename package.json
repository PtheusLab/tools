{
  "name": "@ptheus/tools",
  "version": "0.1.1",
  "description": "A collection of ready-to-use web scrapers as importable functions",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./scrapers/*": {
      "import": "./dist/scrapers/*.mjs",
      "require": "./dist/scrapers/*.js",
      "types": "./dist/scrapers/*.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "scraper",
    "web-scraper",
    "tools",
    "typescript"
  ],
  "author": "ptheus",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PtheusLab/tools.git"
  },
  "homepage": "https://github.com/PtheusLab/tools#readme",
  "bugs": {
    "url": "https://github.com/PtheusLab/tools/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "ofetch": "^1.4.0",
    "zod": "^3.25.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
